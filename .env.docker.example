# Docker full-stack example — copy to .env for docker-compose.full.yml
NODE_ENV=production
PORT=3000
API_PREFIX=/api

DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=anchor_user
DB_PASSWORD=change_me_db_password
DB_DATABASE=anchor_db

MYSQL_ROOT_PASSWORD=change_me_root_password

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRATION=1d
JWT_REFRESH_EXPIRATION=7d

CORS_ORIGIN=https://app.anchorworld.org
SOCKET_CORS_ORIGIN=https://app.anchorworld.org
FRONTEND_URL=https://app.anchorworld.org

UPLOAD_DIR=uploads
MAX_FILE_SIZE=20971520
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,video/mp4,video/quicktime,video/webm

FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

RUN_SEED_ON_START=true
