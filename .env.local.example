# Local development — copy to .env when running on your machine
# Do NOT commit .env

NODE_ENV=development
PORT=3000
API_PREFIX=/api

# Local MySQL (start with: docker compose up -d)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USERNAME=anchor_user
DB_PASSWORD=anchor_pass
DB_DATABASE=anchor_db

JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

CORS_ORIGIN=http://localhost:3001
SOCKET_CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001

UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Email optional for local dev
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@anchorheart.app
