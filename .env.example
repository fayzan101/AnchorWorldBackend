# Copy to `.env` for local development (MySQL via `npm run db:up`)

NODE_ENV=development
PORT=3000
API_PREFIX=/api

DB_HOST=localhost
DB_PORT=3307
DB_USERNAME=anchor_user
DB_PASSWORD=anchor_pass
DB_DATABASE=anchor_db

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

CORS_ORIGIN=http://localhost:3001
SOCKET_CORS_ORIGIN=http://localhost:3001

UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Required for forgot-password emails (welcome email is optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@anchorworld.org
# Link base used in password-reset emails (must open the app deep link / web reset screen)
FRONTEND_URL=https://app.anchorworld.org

# Optional — push notifications disabled if file is missing
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Guided video intros (Agora RTC)
AGORA_APP_ID=8aa7f7835089465caa86c5d8ac2afac5
AGORA_APP_CERTIFICATE=970831e352814e45a01cf99b15142c89

# RevenueCat (Premium IAP)
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_ENTITLEMENT_ID=premium

# Comma-separated user UUIDs allowed to access /api/admin/*
# ADMIN_USER_IDS=uuid-1,uuid-2
